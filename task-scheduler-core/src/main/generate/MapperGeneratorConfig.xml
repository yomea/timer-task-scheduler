<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration
        PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">

<generatorConfiguration>

  <context id="mysql_tables" targetRuntime="MyBatis3">

    <!-- 不需要生成注释
 <commentGenerator>
   <property name="suppressAllComments" value="true" />
   <property name="suppressDate" value="true" />
 </commentGenerator>
  -->
    <!-- 注释控制完毕 -->

    <!-- 这里的type里写的是你的实现类的类全路径 -->
    <commentGenerator type="org.mybatis.generator.api.dom.MyCommentGenerator">
    </commentGenerator>
    <jdbcConnection driverClass="com.mysql.jdbc.Driver"
                    connectionURL="jdbc:mysql://10.0.10.41:3306/obs?autoReconnect=true&amp;failOverReadOnly=false&amp;maxReconnects=10&amp;characterEncoding=UTF8"
                    userId="root"
                    password="shinemo123">
    </jdbcConnection>

    <javaTypeResolver >
      <property name="forceBigDecimals" value="false" />
    </javaTypeResolver>

    <javaModelGenerator targetPackage="com.shinemo.task.core.dal.model" targetProject="src/main/java">
      <property name="enableSubPackages" value="true" />
      <property name="trimStrings" value="true" />
    </javaModelGenerator>

    <javaQueryGenerator targetPackage="com.shinemo.task.core.dal.model" targetProject="src/main/java">
      <property name="enableSubPackages" value="true"/>
      <property name="trimStrings" value="true"/>
    </javaQueryGenerator>

    <javaUpdateGenerator targetPackage="com.shinemo.task.core.dal.model" targetProject="src/main/java">
      <property name="enableSubPackages" value="true"/>
      <property name="trimStrings" value="true"/>
      <property name="constructorBased" value="true"/>
    </javaUpdateGenerator>

    <sqlMapGenerator targetPackage="mybatis"  targetProject="src/main/resources">
      <property name="enableSubPackages" value="true" />
    </sqlMapGenerator>

    <javaClientGenerator type="XMLMAPPER" targetPackage="com.shinemo.task.core.dal.mapper" targetProject="src/main/java">
      <property name="enableSubPackages" value="true" />
    </javaClientGenerator>



